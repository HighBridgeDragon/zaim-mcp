{
  "name": "@highbridgedragon/zaim-mcp",
  "version": "1.0.1",
  "type": "module",
  "description": "Zaim MCP Server - Access Zaim household finance data via Model Context Protocol",
  "main": "build/index.js",
  "bin": {
    "zaim-mcp": "./build/cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome ci src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "bun test src/__tests__",
    "test:integration": "bun test src/__integration__",
    "check": "biome check --write src/ && tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/HighBridgeDragon/zaim-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "oauth-1.0a": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
